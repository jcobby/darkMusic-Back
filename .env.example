# ---- Server ----
PORT=5000
# Allowed frontend origin for CORS
CLIENT_URL=http://localhost:3000
# Public base URL of THIS API (used to build image + download URLs)
API_BASE_URL=http://localhost:5000

# ---- MongoDB ----
# Local:  mongodb://127.0.0.1:27017/darkyard
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/darkyard
MONGODB_URI=mongodb://127.0.0.1:27017/darkyard

# ---- Admin login ----
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_EMAIL=lenkogh.music@gmail.com
# Plaintext password (hashed in-memory at boot) or a precomputed bcrypt hash ($2...)
ADMIN_PASSWORD=darkyard-admin

# ---- Paystack (https://dashboard.paystack.com/#/settings/developers) ----
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxx
CURRENCY=GHS

# ---- Contact ----
WHATSAPP_NUMBER=233000000000
CONTACT_EMAIL=lenkogh.music@gmail.com

# ---- Optional email notifications (SMTP). Leave blank to disable. ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
